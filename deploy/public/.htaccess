Options -MultiViews
RewriteEngine On

# Social media / OG preview: redirect /analiza/:id to OG HTML endpoint
# Applied unconditionally — bots get OG tags, humans get JS-redirected back with ?view=1
# Skip if ?view=1 is present (human returning from OG page via JS redirect)
RewriteCond %{QUERY_STRING} !(?:^|&)view=1(?:&|$)
RewriteRule ^analiza/([^/]+)/?$ /api/vision/og/analiza/$1 [L,R=302]

# SPA fallback: serve index.html for all non-file paths
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]

<IfModule mod_headers.c>
  # Service worker & index.html — never cache (must check for updates)
  <FilesMatch "^(sw\.js|index\.html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Hashed assets (JS/CSS with fingerprint in name) — cache 1 year
  <FilesMatch "\.[0-9a-f]{8}\.(js|css|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
